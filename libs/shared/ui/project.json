{
  "name": "ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/ui/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/shared/ui"],
      "options": {
        "parallel": false,
        "commands": [
          "mkdir -p dist/libs/shared/ui/src/lib",
          "npx tsc -p libs/shared/ui/tsconfig.lib.json --outDir dist/libs/shared/ui",
          "cp libs/shared/ui/package.json dist/libs/shared/ui/package.json",
          "cp libs/shared/ui/README.md dist/libs/shared/ui/README.md",
          "cp -R libs/shared/ui/src/lib dist/libs/shared/ui/src/lib"
        ]
      }
    },
    "publish": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public --otp=$NPM_OTP",
        "cwd": "dist/libs/shared/ui"
      }
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["^nx-release-publish"]
    }
  }
}
