{
    "$schema": "https://tr.designtokens.org/format/",
    "$metadata": {
        "exportedAt": "2024-01-01T00:00:00.000Z",
        "source": "Figma Variables (plugin: Variables to JSON)"
    },
    "global": {
        "color": {
            "white": { "$value": "#ffffff", "$type": "color" },
            "black": { "$value": "#000000", "$type": "color" },
            "blue": {
                "50":  { "$value": "#eff6ff", "$type": "color" },
                "100": { "$value": "#dbeafe", "$type": "color" },
                "500": { "$value": "#3b82f6", "$type": "color" },
                "600": { "$value": "#2563eb", "$type": "color" },
                "700": { "$value": "#1d4ed8", "$type": "color" }
            },
            "gray": {
                "50":  { "$value": "#f9fafb", "$type": "color" },
                "100": { "$value": "#f3f4f6", "$type": "color" },
                "200": { "$value": "#e5e7eb", "$type": "color" },
                "300": { "$value": "#d1d5db", "$type": "color" },
                "400": { "$value": "#9ca3af", "$type": "color" },
                "500": { "$value": "#6b7280", "$type": "color" },
                "600": { "$value": "#4b5563", "$type": "color" },
                "700": { "$value": "#374151", "$type": "color" }
            },
            "red": {
                "500": { "$value": "#ef4444", "$type": "color" },
                "600": { "$value": "#dc2626", "$type": "color" },
                "700": { "$value": "#b91c1c", "$type": "color" }
            },
            "purple": {
                "500": { "$value": "#8b5cf6", "$type": "color" },
                "600": { "$value": "#7c3aed", "$type": "color" },
                "700": { "$value": "#6d28d9", "$type": "color" }
            }
        },
        "spacing": {
            "xs": { "$value": "0.25rem", "$type": "dimension" },
            "sm": { "$value": "0.5rem",  "$type": "dimension" },
            "md": { "$value": "1rem",    "$type": "dimension" },
            "lg": { "$value": "1.5rem",  "$type": "dimension" },
            "xl": { "$value": "2rem",    "$type": "dimension" },
            "2xl": { "$value": "3rem",   "$type": "dimension" }
        },
        "border": {
            "radius": {
                "sm": { "$value": "0.25rem",  "$type": "dimension" },
                "md": { "$value": "0.375rem", "$type": "dimension" },
                "lg": { "$value": "0.5rem",   "$type": "dimension" }
            }
        }
    },
    "semantic/default": {
        "brand": {
            "primary": { "$value": "{color.red.600}", "$type": "color" },
            "hover":   { "$value": "{color.red.700}", "$type": "color" }
        },
        "surface": {
            "base":  { "$value": "{color.white}",     "$type": "color" },
            "muted": { "$value": "{color.gray.100}",  "$type": "color" }
        },
        "text": {
            "base":     { "$value": "{color.gray.700}", "$type": "color" },
            "muted":    { "$value": "{color.gray.500}", "$type": "color" },
            "on-brand": { "$value": "{color.white}",    "$type": "color" }
        },
        "border": {
            "default": { "$value": "{color.gray.200}", "$type": "color" }
        }
    },
    "semantic/brand-purple": {
        "brand": {
            "primary": { "$value": "{color.purple.600}", "$type": "color" },
            "hover":   { "$value": "{color.purple.700}", "$type": "color" }
        },
        "surface": {
            "base":  { "$value": "{color.white}",    "$type": "color" },
            "muted": { "$value": "{color.gray.100}", "$type": "color" }
        },
        "text": {
            "base":     { "$value": "{color.gray.700}", "$type": "color" },
            "muted":    { "$value": "{color.gray.500}", "$type": "color" },
            "on-brand": { "$value": "{color.white}",    "$type": "color" }
        },
        "border": {
            "default": { "$value": "{color.gray.200}", "$type": "color" }
        }
    }
}
