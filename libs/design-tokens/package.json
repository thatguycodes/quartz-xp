{
  "name": "@thatguycodes/design-tokens",
  "version": "0.2.3",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "sideEffects": false,
  "files": [
    "generated/**",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/generated/js/es6/tokens.d.ts",
      "default": "./src/generated/js/es6/tokens.js"
    },
    "./css/*": "./src/generated/css/*.css",
    "./scss/*": "./src/generated/scss/*.scss",
    "./json/*": "./src/generated/json/*.json",
    "./js/*": "./src/generated/js/*.js"
  },
  "types": "./src/generated/ts/tokens.d.ts",
  "main": "./src/generated/ts/tokens.ts"
}
